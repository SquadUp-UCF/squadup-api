# MongoDB connection string (e.g. mongodb://localhost:27017/squadup)
MONGO_URI=MONGO_URI

# Secret used to sign JWT access tokens
JWT_SECRET=JWT_SECRET

# JWT lifetime (e.g. 1d, 12h, 3600s)
JWT_EXPIRES_IN=7d

# HTTP port the API listens on
PORT=5000

# Optional: the Have I Been Pwned breach check on registration is enabled by
# default. Set to `false` to disable it (e.g. offline development).
# PWNED_PASSWORD_CHECK=false
